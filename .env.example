# Mot de passe requis pour se connecter a l'application
APP_PASSWORD=change-me

# Port d'ecoute du serveur
PORT=3000

# Mettre a true si l'app est servie derriere HTTPS (reverse proxy, VPN...)
# Laisser a false pour un usage en HTTP simple sur reseau local (compatible liseuses)
COOKIE_SECURE=false

# Duree de vie de la session en secondes (defaut: 30 jours)
SESSION_TTL_SECONDS=2592000
